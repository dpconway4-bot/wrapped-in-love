{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3.2.22"
    }
  },
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/webhook.ts" },
    { "source": "/api/journal/:day", "destination": "/api/journal/[day].ts" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/public/index.html" }
  ]
}
